{
  "name": "topaz",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "// --- CORE ---": "",
    "start": "react-native start",
    "test": "jest",
    "setup": "npm i --force && npm run pods && npm run clean",
    "clean": "npm cache clean --force && watchman watch-del-all && rm -rf android/app/.cxx android/.gradle && cd android && ./gradlew clean",
    "reset-cache": "watchman watch-del-all && npx react-native start --reset-cache",
    "pods": "cd ios && bundle install && bundle exec pod install",
    "postinstall": "patch-package",
    "// --- LINT & FORMAT ---": "",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "fix": "npm run format && npm run lint:fix",
    "// --- IOS DEVELOPMENT ---": "",
    "ios": "react-native run-ios",
    "// --- ANDROID DEVELOPMENT ---": "",
    "android": "react-native run-android",
    "// --- MULTI-PLATFORM DEVELOPMENT ---": "",
    "run-all": "npm run android && npm run ios",
    "// --- VERSIONING ---": "",
    "version:patch": "npm run android:bump:patch && npm run ios:bump:patch",
    "android:bump:patch": "cd android && bundle exec fastlane bump type:patch",
    "ios:bump:patch": "cd ios && bundle exec fastlane bump type:patch",
    "// --- BUILD & EXPORT (Local) ---": "",
    "build:android-aab": "ENVFILE=.env npx react-native build-android --mode productionRelease",
    "build:android-apk": "ENVFILE=.env cd android && ./gradlew assembleProductionRelease && cd ../"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/bottom-tabs": "^7.18.7",
    "@react-navigation/material-top-tabs": "^7.6.6",
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.17.9",
    "axios": "^1.18.1",
    "lucide-react-native": "^1.23.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-config": "^1.6.1",
    "react-native-pager-view": "^8.0.3",
    "react-native-reanimated": "^4.5.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "^0.10.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "postcss": "^8.5.16",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
